# ===== الإعدادات الرئيسية =====
PORT=3000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/coopbot

# ===== Discord OAuth2 (للداشبورد) =====
DISCORD_CLIENT_ID=YOUR_DISCORD_APP_CLIENT_ID
DISCORD_CLIENT_SECRET=YOUR_DISCORD_APP_CLIENT_SECRET
DISCORD_CALLBACK_URL=https://yourdomain.com/auth/discord/callback

# ===== Session Secret =====
SESSION_SECRET=change_this_to_random_long_string_123456789

# ===== Admin Panel =====
ADMIN_PASSWORD=your_admin_password_here

